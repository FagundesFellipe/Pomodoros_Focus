#!/bin/sh
# Pre-commit hook: roda testes e verifica cobertura >= 80%

echo ""
echo "========================================"
echo "  Pre-commit: Rodando testes + coverage"
echo "========================================"
echo ""

# Verifica se pytest está disponível
if ! command -v pytest >/dev/null 2>&1; then
    echo "Erro: pytest não encontrado."
    echo "Instale as dependências de dev: pip install -e '.[dev]'"
    exit 1
fi

# Roda testes com cobertura e fail_under=80
pytest --cov=mr_consultor --cov-report=term-missing --cov-fail-under=80 -v
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "========================================"
    echo "  COMMIT BLOQUEADO"
    echo "  Motivo: testes falharam ou cobertura < 80%"
    echo "========================================"
    exit 1
fi

echo ""
echo "========================================"
echo "  Testes e cobertura OK - commit liberado"
echo "========================================"
exit 0
